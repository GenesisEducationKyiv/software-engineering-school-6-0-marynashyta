{
    "name": "release-notification/api",
    "description": "GitHub Release Notification API",
    "type": "project",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "guzzlehttp/guzzle": "^7.8",
        "phpmailer/phpmailer": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "predis/predis": "^3.0",
        "php-di/php-di": "^7.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^4.0",
        "playwright-php/playwright": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:integration": "phpunit -c phpunit.integration.xml",
        "test:e2e": "phpunit -c phpunit.e2e.xml",
        "lint": "phpstan analyse",
        "cs": "phpcs",
        "cs-fix": "phpcbf",
        "start": "php -S localhost:8080 -t public"
    }
}
